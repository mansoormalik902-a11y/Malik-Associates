<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
background:#f5f7fa;
}

header{
background:#003366;
color:white;
text-align:center;
padding:40px 20px;
}

header img{
width:120px;
margin-bottom:15px;
}

nav{
background:#002244;
padding:15px;
text-align:center;
}

nav a{
color:white;
text-decoration:none;
margin:0 15px;
font-weight:bold;
}

.hero{
padding:60px 20px;
text-align:center;
background:white;
}

.hero h1{
color:#003366;
font-size:42px;
margin-bottom:20px;
}

.hero p{
max-width:900px;
margin:auto;
font-size:18px;
}

.container{
max-width:1200px;
margin:auto;
padding:40px 20px;
}

.card{
background:white;
padding:40px;
border-radius:15px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
text-align:center;
}

.card h2{
color:#003366;
margin-bottom:20px;
}

.btn{
display:inline-block;
padding:15px 30px;
background:#d4af37;
color:#003366;
font-weight:bold;
text-decoration:none;
border-radius:8px;
margin-top:20px;
}

.pdf-viewer{
margin-top:40px;
border-radius:15px;
overflow:hidden;
box-shadow:0 10px 25px rgba(0,0,0,.08);
}

iframe{
width:100%;
height:900px;
border:none;
}

footer{
background:#003366;
color:white;
text-align:center;
padding:30px;
margin-top:50px;
}

</style>
</head>

